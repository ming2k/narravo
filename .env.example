# Azure Speech Service Configuration
# Get these values from your Azure Speech Service resource in the Azure portal
# Sign up at: https://azure.microsoft.com/services/cognitive-services/speech-services/

# Your Azure Speech Service subscription key
VITE_AZURE_SPEECH_KEY=your_azure_speech_service_key_here

# The Azure region where your Speech Service resource is deployed
# Examples: eastus, westus2, northeurope, southeastasia
VITE_AZURE_REGION=your_azure_region_here

# Development only: automatically apply the Azure values above to
# browser.storage.local and mark onboarding as completed when running `npm run dev`.
# This is ignored unless set to "true".
VITE_NARRAVO_DEV_AUTO_SETUP=false

# Optional development overrides
# VITE_NARRAVO_DEV_VOICE=en-US-AvaMultilingualNeural
# VITE_NARRAVO_DEV_RATE=1
# VITE_NARRAVO_DEV_PITCH=1

# Optional: Set to 'development' or 'production'
NODE_ENV=development
