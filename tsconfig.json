{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["DOM", "DOM.Iterable", "ESNext"],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "forceConsistentCasingInFileNames": true,
    "noEmit": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "baseUrl": ".",
    "paths": {
      "@@/*": ["./*"],
      "~/*": ["./src/*"]
    }
  },
  "include": [
    ".wxt/types/*.d.ts",
    "src/**/*",
    "wxt.config.ts"
  ],
  "exclude": ["node_modules"]
}
